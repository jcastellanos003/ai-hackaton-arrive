{
  "permissions": {
    "allow": [
      "Bash(pnpm dlx *)",
      "Bash(pnpm run *)",
      "Bash(pnpm dev *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(curl -s -o /dev/null -w \"Cart: %{http_code}\\\\n\" http://localhost:3000/cart)",
      "Bash(curl -s -o /dev/null -w \"Checkout: %{http_code}\\\\n\" http://localhost:3000/checkout)",
      "Bash(curl -s -o /dev/null -w \"Product detail: %{http_code}\\\\n\" http://localhost:3000/products/p-001)",
      "Bash(curl -s -o /dev/null -w \"Order confirmation: %{http_code}\\\\n\" \"http://localhost:3000/order-confirmation?orderId=test\")",
      "Bash(pkill -f \"next dev\")"
    ]
  }
}
